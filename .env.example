# Database (SQLite by default — no install needed)
DATABASE_URL=sqlite+aiosqlite:///./aventuria_vtt.db
DATABASE_URL_SYNC=sqlite:///./aventuria_vtt.db

# For PostgreSQL (optional, if you install it later):
# DATABASE_URL=postgresql+asyncpg://aventuria:aventuria@localhost:5432/aventuria_vtt
# DATABASE_URL_SYNC=postgresql://aventuria:aventuria@localhost:5432/aventuria_vtt

# Redis (leave empty to use in-memory fallback)
REDIS_URL=

# Auth — MUST be overridden before exposing the backend on any network.
# JWTs are signed with this value; anyone who knows it can forge any token.
# Generate a strong value with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=dev-secret-key-change-in-production

# Environment gate. When ENV=production, the backend refuses to start with the
# dev-default SECRET_KEY above. Leave as "development" for local work.
ENV=development

# AI (optional — leave empty to disable AI features)
ANTHROPIC_API_KEY=

# App
CORS_ORIGINS=http://localhost:5173

# Dev conveniences — NEVER set on a public deployment.
# SEED_TEST_USERS=true seeds gm@test.de + 4 player accounts (password "test1234")
# and a pre-built demo campaign when `python -m databank.seed` runs.
SEED_TEST_USERS=false
